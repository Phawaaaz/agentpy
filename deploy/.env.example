# Copy to .env and fill in.  cp .env.example .env

# --- required ---------------------------------------------------------------

# PostgreSQL password (used by the db + backend containers).
POSTGRES_PASSWORD=change-me-to-a-strong-password

# JWT signing secret. Generate a long random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Keep it stable — changing it logs everyone out.
HARNESS_JWT_SECRET=paste-a-long-random-string-here

# First admin account. Set these to seed ONE real admin and skip the demo
# alice/bob accounts entirely (recommended for production). Leave both unset
# to get the alice/bob demo logins instead.
# HARNESS_ADMIN_USERNAME=admin
# HARNESS_ADMIN_PASSWORD=change-me

# --- model (optional) -------------------------------------------------------
# Leave as-is for the offline scripted agent (no key needed). To use a real
# model, set these. Examples:
#   Internal / OpenAI-compatible endpoint:
#     HARNESS_MODEL=openai/your-model
#     HARNESS_BASE_URL=https://llm.yourcompany.com
#     HARNESS_API_KEY=sk-...
#   Anthropic:
#     HARNESS_MODEL=anthropic/claude-sonnet-5
#     HARNESS_API_KEY=sk-ant-...
HARNESS_MODEL=demo/scripted
HARNESS_BASE_URL=
HARNESS_API_KEY=
# Optional fallback chain, comma-separated (tried left to right on failure):
#   HARNESS_FALLBACK_MODEL=gemini/gemini-2.0-flash,groq/llama-3.3-70b-versatile
HARNESS_FALLBACK_MODEL=
# For prefix-specific keys used by a fallback, add them here too, e.g.:
# GEMINI_API_KEY=
# GROQ_API_KEY=

# --- serving (optional) -----------------------------------------------------
# Port the app is published on. 80 = plain http://server/. Put a TLS proxy in
# front for https in production (see DEPLOY.md).
HTTP_PORT=80

# --- GitHub "Connect GitHub" (optional) -------------------------------------
# Lets each user authorize their own GitHub from the app (OAuth). Register a
# GitHub OAuth App (https://github.com/settings/developers), set its callback
# to  https://<your-domain>/oauth/github/callback , then fill these in:
# HARNESS_GITHUB_CLIENT_ID=
# HARNESS_GITHUB_CLIENT_SECRET=
# Public URL of the app so the OAuth callback is built correctly (must match
# the OAuth App's callback host). e.g. https://ai.floowpay.com
# HARNESS_PUBLIC_URL=
