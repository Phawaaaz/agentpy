# Copy this file to ".env" and fill in your values.
# The harness is model-independent: change HARNESS_MODEL + the key, nothing else.

# Which model to use. Format: "<provider>/<model>". Known prefixes:
#   anthropic/claude-opus-4-8
#   openai/gpt-4o
#   openrouter/<model>       (any model on OpenRouter)
#   groq/<model>             (Groq)
#   together/<model>         (Together AI)
#   ollama/llama3            (local; no real key needed)
HARNESS_MODEL=anthropic/claude-opus-4-8

# The API key for whichever provider you chose above.
HARNESS_API_KEY=

# Optional: point the OpenAI-compatible client at any custom endpoint
# (LM Studio, vLLM, a self-hosted gateway). Leave blank for the defaults above.
HARNESS_BASE_URL=

# Optional: max tokens the model may generate per turn (Anthropic requires this).
HARNESS_MAX_TOKENS=4096

# Context management: once history is estimated to exceed this many tokens, the
# oldest messages are folded into a summary so the window doesn't overflow.
HARNESS_MAX_CONTEXT_TOKENS=100000
HARNESS_KEEP_RECENT_MESSAGES=20

# Where saved sessions and event logs are written (relative to the run dir).
HARNESS_SESSIONS_DIR=.harness/sessions
HARNESS_LOGS_DIR=.harness/logs

# Permission mode: how the agent behaves before taking an action.
#   ask       -> auto-allow reads; prompt you before writes / shell / risky actions
#   allowlist -> run safe + write actions automatically; block dangerous ones (no prompts)
#   auto      -> run everything without asking (use only in a sandbox)
HARNESS_PERMISSION_MODE=ask

# Safety cap on how many tool-using steps one task may take.
HARNESS_MAX_STEPS=25

# MCP servers to connect to at startup. Claude-Desktop-style config file; see
# mcp.json.example (copy to .harness/mcp.json, or point this at your own path).
# Leave the file absent to skip MCP entirely.
HARNESS_MCP_CONFIG=.harness/mcp.json

# Where the memory tool and the automatic activity tracker write notes.
HARNESS_MEMORY_DIR=.harness/memory

# --- Autonomous pipeline (pipeline.py) --------------------------------------
# Max "implement" iterations before a slice gives up.
HARNESS_PIPELINE_MAX_ITERATIONS=20
# Auto-stop after this many consecutive iterations with no git diff change.
HARNESS_PIPELINE_STUCK_AFTER=3
# Wall-clock budget per slice, in seconds.
HARNESS_PIPELINE_SLICE_TIMEOUT=1800
# Repair attempts allowed after a failed test stage, separate from the main
# iteration budget.
HARNESS_PIPELINE_MAX_REPAIR_ATTEMPTS=5
